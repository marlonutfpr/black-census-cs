# Copie este arquivo para  .streamlit/secrets.toml  (já está no .gitignore)
# e cole a connection string do seu projeto Supabase.
#
# Onde pegar no painel do Supabase:
#   1. Abra seu projeto em https://supabase.com/dashboard
#   2. Clique no botão "Connect" (topo da página)
#   3. Aba "Connection string" -> seção "Session pooler"
#   4. Copie a URI e troque [YOUR-PASSWORD] pela senha do banco
#      (definida na criação do projeto; pode ser redefinida em
#       Project Settings -> Database -> "Database password" -> Reset)
#
# Use o "Session pooler" (porta 5432) — IPv4, suporta COPY e transações.

[supabase]
db_url = "postgresql://postgres.<project-ref>:<YOUR-PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres"
